# NOTE: This file is unused on this server (Nginx). Kept for reference only.

<IfModule mod_rewrite.c>
    Options -MultiViews
    RewriteEngine On

    # Route all requests that are not real files or directories to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Deny access to .env and hidden files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
