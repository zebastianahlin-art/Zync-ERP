# Application
APP_NAME="ZYNC ERP"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Europe/Stockholm

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zync_erp
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# JWT (for future use)
JWT_SECRET=generate-at-least-64-chars-with-openssl-rand-hex-32
JWT_ALGO=HS256
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Session
SESSION_LIFETIME=28800
SESSION_SECURE=true

# Encryption (for future use)
ENCRYPTION_KEY=generate-64-char-hex-with-openssl-rand-hex-32

# Admin seed credentials (used by bin/seed.php)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_seeding

# Logging
LOG_LEVEL=error
