# Application
APP_NAME="ZYNC ERP"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zync_erp
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Admin seed credentials (used by bin/seed.php)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_seeding

# Logging
LOG_LEVEL=error
